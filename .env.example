# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# In Next.js, use NEXT_PUBLIC_GEMINI_API_KEY for client-side usage.
NEXT_PUBLIC_GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL connection string for the app's dedicated database.
DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_SSL=false

# JWT_SECRET: Secret used to sign session tokens (auth). Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Odoo Integration
ODOO_URL=https://systemsat.odoo.com
ODOO_DB=systemsat
ODOO_USERNAME=rodolfo.quintanilha@systemsat.com.br
ODOO_API_KEY=1c2b90a140f7fe906456c70e8e47e39e2bd50baf

# Bitrix Integration
BITRIX_WEBHOOK=https://systemsat.bitrix24.com.br/rest/54/y9yqvxtdwvccpsr1/

# Encryption Key (32 bytes / 64 hex characters)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=9f3c8a1b7e2d4c6f8a9b0d1e2f3a4c5d6e7f8091a2b3c4d5e6f708192a3b4c5d