NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRwYWFuaGhybmF2dG13dGptdnFmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ5MzI2MzQsImV4cCI6MjA5MDUwODYzNH0.Nv5N_i-E-bctSEZIh8RXlKcBulhaQcF12JV57ZBqKQc
